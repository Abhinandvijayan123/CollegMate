<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CollegMate 🎓 — Find Your Campus Person</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800;900&family=Pacifico&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --primary: #6c47ff;
      --secondary: #ff6b9d;
      --accent: #ffd166;
      --teal: #06d6a0;
      --bg: #f4f0ff;
      --card: #ffffff;
      --text: #1a0533;
      --sub: #7a6b8a;
      --grad: linear-gradient(135deg, #6c47ff, #ff6b9d);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Poppins', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* ── PAGES ── */
    .page { display: none; min-height: 100vh; }
    .page.active { display: flex; flex-direction: column; }

    /* ── SPLASH ── */
    #splash {
      background: var(--grad);
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem;
      position: relative;
      overflow: hidden;
    }
    #splash::before {
      content: '';
      position: absolute;
      width: 600px; height: 600px;
      background: rgba(255,255,255,0.07);
      border-radius: 50%;
      top: -150px; right: -150px;
    }
    #splash::after {
      content: '';
      position: absolute;
      width: 400px; height: 400px;
      background: rgba(255,255,255,0.05);
      border-radius: 50%;
      bottom: -100px; left: -100px;
    }
    .splash-emoji { font-size: 4rem; margin-bottom: 1rem; animation: bounce 1.5s infinite; }
    .splash-logo {
      font-family: 'Pacifico', cursive;
      font-size: 3.5rem;
      color: white;
      text-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }
    .splash-tagline {
      color: rgba(255,255,255,0.85);
      font-size: 1rem;
      font-weight: 600;
      margin: 0.8rem 0 2.5rem;
    }
    .splash-btns { display: flex; flex-direction: column; gap: 1rem; width: 100%; max-width: 320px; }
    .btn-white {
      background: white;
      color: var(--primary);
      border: none;
      padding: 1rem;
      border-radius: 16px;
      font-size: 1rem;
      font-weight: 800;
      cursor: pointer;
      font-family: 'Poppins', sans-serif;
      box-shadow: 0 6px 24px rgba(0,0,0,0.15);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-white:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(0,0,0,0.2); }
    .btn-outline-white {
      background: transparent;
      color: white;
      border: 2.5px solid rgba(255,255,255,0.7);
      padding: 1rem;
      border-radius: 16px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      font-family: 'Poppins', sans-serif;
      transition: background 0.2s;
    }
    .btn-outline-white:hover { background: rgba(255,255,255,0.15); }

    /* ── ONBOARDING ── */
    #onboarding {
      background: var(--bg);
      padding: 0;
    }
    .onboard-header {
      background: var(--grad);
      padding: 3rem 2rem 2rem;
      color: white;
      text-align: center;
    }
    .onboard-header h1 { font-family: 'Pacifico', cursive; font-size: 2rem; }
    .onboard-header p { font-size: 0.9rem; opacity: 0.85; margin-top: 0.3rem; font-weight: 600; }
    .progress-bar {
      height: 5px;
      background: rgba(255,255,255,0.3);
      border-radius: 99px;
      margin-top: 1.2rem;
      overflow: hidden;
    }
    .progress-fill {
      height: 100%;
      background: white;
      border-radius: 99px;
      transition: width 0.4s ease;
    }

    .onboard-body { padding: 2rem 1.5rem; flex: 1; }
    .step-panel { display: none; animation: fadeIn 0.4s ease; }
    .step-panel.active { display: block; }
    .step-label {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--primary);
      margin-bottom: 0.4rem;
    }
    .step-title {
      font-size: 1.6rem;
      font-weight: 900;
      color: var(--text);
      margin-bottom: 0.3rem;
      line-height: 1.2;
    }
    .step-sub { font-size: 0.88rem; color: var(--sub); font-weight: 600; margin-bottom: 1.8rem; }

    .form-field {
      margin-bottom: 1.2rem;
    }
    .form-field label {
      display: block;
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--sub);
      margin-bottom: 0.4rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .form-field input,
    .form-field select,
    .form-field textarea {
      width: 100%;
      border: 2.5px solid #e5daf5;
      border-radius: 14px;
      padding: 0.85rem 1rem;
      font-size: 0.95rem;
      font-family: 'Poppins', sans-serif;
      color: var(--text);
      background: white;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .form-field input:focus,
    .form-field select:focus,
    .form-field textarea:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 4px rgba(108,71,255,0.1);
    }
    .form-field textarea { resize: none; height: 110px; }
    .char-count { font-size: 0.75rem; color: var(--sub); text-align: right; margin-top: 0.2rem; }

    .gender-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.8rem;
    }
    .gender-btn {
      border: 2.5px solid #e5daf5;
      background: white;
      border-radius: 14px;
      padding: 1rem;
      cursor: pointer;
      text-align: center;
      font-family: 'Poppins', sans-serif;
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--sub);
      transition: all 0.2s;
    }
    .gender-btn .gender-icon { font-size: 1.8rem; display: block; margin-bottom: 0.3rem; }
    .gender-btn.selected {
      border-color: var(--primary);
      background: #f0ebff;
      color: var(--primary);
    }

    .btn-next {
      width: 100%;
      background: var(--grad);
      color: white;
      border: none;
      padding: 1rem;
      border-radius: 16px;
      font-size: 1rem;
      font-weight: 800;
      cursor: pointer;
      font-family: 'Poppins', sans-serif;
      margin-top: 1.5rem;
      box-shadow: 0 6px 20px rgba(108,71,255,0.35);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-next:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(108,71,255,0.45); }
    .btn-back {
      width: 100%;
      background: transparent;
      color: var(--sub);
      border: none;
      padding: 0.7rem;
      font-size: 0.9rem;
      font-weight: 700;
      cursor: pointer;
      font-family: 'Poppins', sans-serif;
      margin-top: 0.5rem;
    }

    /* ── LOGIN ── */
    #login {
      align-items: center;
      justify-content: center;
      padding: 2rem;
      background: var(--bg);
    }
    .login-box {
      background: white;
      border-radius: 24px;
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 380px;
      box-shadow: 0 20px 60px rgba(108,71,255,0.12);
      text-align: center;
    }
    .login-logo { font-family: 'Pacifico', cursive; font-size: 2rem; color: var(--primary); margin-bottom: 0.5rem; }
    .login-sub { color: var(--sub); font-size: 0.88rem; font-weight: 600; margin-bottom: 1.8rem; }
    .login-box .form-field { text-align: left; }
    .btn-login {
      width: 100%;
      background: var(--grad);
      color: white;
      border: none;
      padding: 1rem;
      border-radius: 14px;
      font-size: 1rem;
      font-weight: 800;
      cursor: pointer;
      font-family: 'Poppins', sans-serif;
      margin-top: 0.5rem;
      box-shadow: 0 6px 20px rgba(108,71,255,0.3);
      transition: transform 0.2s;
    }
    .btn-login:hover { transform: translateY(-2px); }
    .login-switch { margin-top: 1rem; font-size: 0.85rem; color: var(--sub); font-weight: 600; }
    .login-switch a { color: var(--primary); cursor: pointer; font-weight: 700; text-decoration: none; }

    /* ── MAIN APP ── */
    #app { background: var(--bg); }

    /* Top bar */
    .topbar {
      background: white;
      padding: 1rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 2px 12px rgba(108,71,255,0.08);
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .topbar-logo { font-family: 'Pacifico', cursive; font-size: 1.5rem; color: var(--primary); }
    .topbar-actions { display: flex; gap: 0.8rem; }
    .icon-btn {
      width: 40px; height: 40px;
      border-radius: 12px;
      border: none;
      background: var(--bg);
      font-size: 1.2rem;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s;
    }
    .icon-btn:hover { background: #e5daf5; }
    .icon-btn.active { background: #f0ebff; }

    /* Tab nav */
    .tab-nav {
      display: flex;
      background: white;
      border-top: 1px solid #f0e8ff;
      position: fixed;
      bottom: 0; left: 0; right: 0;
      z-index: 50;
    }
    .tab-btn {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 0.8rem 0 0.6rem;
      font-size: 1.3rem;
      background: none;
      border: none;
      cursor: pointer;
      color: #c0b0d0;
      font-family: 'Poppins', sans-serif;
      font-size: 0.6rem;
      font-weight: 700;
      gap: 2px;
      transition: color 0.2s;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .tab-btn .tab-icon { font-size: 1.4rem; }
    .tab-btn.active { color: var(--primary); }
    .tab-badge {
      background: var(--secondary);
      color: white;
      font-size: 0.6rem;
      font-weight: 800;
      border-radius: 99px;
      padding: 1px 5px;
      margin-left: 2px;
    }

    /* Swipe screen */
    .swipe-screen {
      padding: 1.5rem 1rem 6rem;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .swipe-screen h2 {
      font-size: 1rem;
      font-weight: 800;
      color: var(--sub);
      margin-bottom: 1.2rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .card-stack {
      position: relative;
      width: 100%;
      max-width: 340px;
      height: 480px;
    }
    .profile-card {
      position: absolute;
      inset: 0;
      background: white;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 16px 40px rgba(0,0,0,0.12);
      transition: transform 0.3s ease;
      cursor: grab;
    }
    .profile-card:nth-child(2) { transform: rotate(-4deg) translateY(10px) scale(0.97); z-index: 1; }
    .profile-card:nth-child(3) { transform: rotate(3deg) translateY(18px) scale(0.94); z-index: 0; }
    .profile-card.top { z-index: 10; }
    .card-avatar {
      height: 280px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 7rem;
      position: relative;
    }
    .card-college-badge {
      position: absolute;
      top: 1rem; left: 1rem;
      background: rgba(255,255,255,0.9);
      backdrop-filter: blur(6px);
      border-radius: 50px;
      padding: 0.3rem 0.8rem;
      font-size: 0.72rem;
      font-weight: 800;
      color: var(--primary);
    }
    .card-body { padding: 1.2rem 1.4rem; }
    .card-name-row {
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
      margin-bottom: 0.3rem;
    }
    .card-name { font-size: 1.3rem; font-weight: 900; }
    .card-age { font-size: 1rem; color: var(--sub); font-weight: 600; }
    .card-bio { font-size: 0.85rem; color: var(--sub); font-weight: 600; line-height: 1.55; }

    .swipe-actions {
      display: flex;
      gap: 1.2rem;
      margin-top: 1.5rem;
      align-items: center;
    }
    .action-btn {
      width: 58px; height: 58px;
      border-radius: 50%;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 6px 20px rgba(0,0,0,0.12);
    }
    .action-btn:hover { transform: scale(1.12); }
    .btn-nope { background: white; }
    .btn-like { background: var(--grad); width: 68px; height: 68px; font-size: 1.7rem; box-shadow: 0 8px 24px rgba(108,71,255,0.4); }
    .btn-super { background: linear-gradient(135deg, var(--accent), #ffa500); }

    .no-more {
      display: none;
      text-align: center;
      padding: 3rem 1.5rem;
    }
    .no-more .big-emoji { font-size: 4rem; }
    .no-more h3 { font-size: 1.3rem; font-weight: 900; margin: 0.8rem 0 0.4rem; }
    .no-more p { color: var(--sub); font-size: 0.9rem; font-weight: 600; }

    /* Matches screen */
    .matches-screen {
      padding: 1.5rem 1rem 6rem;
      display: none;
    }
    .matches-screen.active { display: block; }
    .matches-screen h2 {
      font-size: 1.4rem;
      font-weight: 900;
      margin-bottom: 0.3rem;
    }
    .matches-screen .sub { color: var(--sub); font-size: 0.85rem; font-weight: 600; margin-bottom: 1.5rem; }
    .match-list { display: flex; flex-direction: column; gap: 1rem; }
    .match-card {
      background: white;
      border-radius: 20px;
      padding: 1.2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      box-shadow: 0 4px 16px rgba(0,0,0,0.06);
      cursor: pointer;
      transition: transform 0.2s;
    }
    .match-card:hover { transform: translateX(4px); }
    .match-avatar {
      width: 56px; height: 56px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.8rem;
      flex-shrink: 0;
    }
    .match-info { flex: 1; }
    .match-name { font-weight: 800; font-size: 1rem; }
    .match-college { font-size: 0.78rem; color: var(--sub); font-weight: 600; }
    .match-msg { font-size: 0.82rem; color: var(--primary); font-weight: 700; margin-top: 0.2rem; }
    .match-arrow { color: #ccc; font-size: 1.2rem; }

    /* Profile screen */
    .profile-screen {
      padding: 1.5rem 1rem 6rem;
      display: none;
    }
    .profile-screen.active { display: block; }
    .my-profile-card {
      background: white;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 8px 30px rgba(0,0,0,0.08);
      margin-bottom: 1.5rem;
    }
    .my-profile-header {
      background: var(--grad);
      padding: 2.5rem 1.5rem 1.5rem;
      color: white;
      text-align: center;
    }
    .my-avatar { font-size: 4rem; margin-bottom: 0.5rem; }
    .my-name { font-size: 1.5rem; font-weight: 900; }
    .my-college { font-size: 0.85rem; opacity: 0.85; font-weight: 600; }
    .my-profile-body { padding: 1.5rem; }
    .info-row {
      display: flex;
      justify-content: space-between;
      padding: 0.7rem 0;
      border-bottom: 1px solid #f0e8ff;
      font-size: 0.9rem;
    }
    .info-row:last-child { border-bottom: none; }
    .info-label { color: var(--sub); font-weight: 600; }
    .info-val { font-weight: 700; }
    .logout-btn {
      width: 100%;
      background: #fff0f0;
      color: #e74c3c;
      border: none;
      padding: 1rem;
      border-radius: 16px;
      font-size: 0.95rem;
      font-weight: 800;
      cursor: pointer;
      font-family: 'Poppins', sans-serif;
      transition: background 0.2s;
    }
    .logout-btn:hover { background: #ffd5d5; }

    /* Match popup */
    .match-popup {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(108,71,255,0.85);
      z-index: 999;
      justify-content: center;
      align-items: center;
      padding: 2rem;
    }
    .match-popup.show { display: flex; }
    .match-popup-box {
      background: white;
      border-radius: 28px;
      padding: 2.5rem 2rem;
      text-align: center;
      width: 100%;
      max-width: 360px;
      animation: pop 0.4s cubic-bezier(.36,1.6,.6,1) both;
    }
    .match-popup-box h2 {
      font-family: 'Pacifico', cursive;
      font-size: 2rem;
      background: var(--grad);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 0.4rem;
    }
    .match-popup-avatars { font-size: 3.5rem; margin: 1rem 0; }
    .match-popup-box p { color: var(--sub); font-size: 0.9rem; font-weight: 600; margin-bottom: 1.5rem; }
    .btn-grad {
      width: 100%;
      background: var(--grad);
      color: white;
      border: none;
      padding: 1rem;
      border-radius: 16px;
      font-size: 1rem;
      font-weight: 800;
      cursor: pointer;
      font-family: 'Poppins', sans-serif;
      margin-bottom: 0.8rem;
      box-shadow: 0 6px 20px rgba(108,71,255,0.3);
    }
    .btn-ghost {
      width: 100%;
      background: transparent;
      color: var(--sub);
      border: none;
      padding: 0.6rem;
      font-size: 0.9rem;
      font-weight: 700;
      cursor: pointer;
      font-family: 'Poppins', sans-serif;
    }

    /* Toast */
    .toast {
      position: fixed;
      bottom: 80px; left: 50%; transform: translateX(-50%);
      background: var(--text);
      color: white;
      padding: 0.7rem 1.4rem;
      border-radius: 50px;
      font-size: 0.85rem;
      font-weight: 700;
      z-index: 9999;
      opacity: 0;
      transition: opacity 0.3s;
      pointer-events: none;
      white-space: nowrap;
    }
    .toast.show { opacity: 1; }

    /* Backgrounds for avatars */
    .bg-a { background: linear-gradient(135deg, #ffd6e8, #ffb3cc); }
    .bg-b { background: linear-gradient(135deg, #d6e8ff, #b3d1ff); }
    .bg-c { background: linear-gradient(135deg, #d6ffe8, #b3ffd0); }
    .bg-d { background: linear-gradient(135deg, #fff3d6, #ffe0a0); }
    .bg-e { background: linear-gradient(135deg, #f0d6ff, #ddb3ff); }

    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes pop {
      from { opacity: 0; transform: scale(0.7); }
      to { opacity: 1; transform: scale(1); }
    }
    @keyframes swipeRight {
      to { transform: rotate(20deg) translateX(120%) !important; opacity: 0; }
    }
    @keyframes swipeLeft {
      to { transform: rotate(-20deg) translateX(-120%) !important; opacity: 0; }
    }
    .swipe-right { animation: swipeRight 0.4s ease forwards; }
    .swipe-left { animation: swipeLeft 0.4s ease forwards; }

    .error-msg {
      background: #fff0f0;
      color: #e74c3c;
      border-radius: 10px;
      padding: 0.7rem 1rem;
      font-size: 0.82rem;
      font-weight: 700;
      margin-bottom: 1rem;
      display: none;
    }
  </style>
</head>
<body>

<!-- ── SPLASH ── -->
<div id="splash" class="page active">
  <div class="splash-emoji">🎓</div>
  <div class="splash-logo">CollegMate</div>
  <div class="splash-tagline">Meet your campus person. For real this time. 💜</div>
  <div class="splash-btns">
    <button class="btn-white" onclick="showPage('onboarding')">✨ Create Profile</button>
    <button class="btn-outline-white" onclick="showPage('login')">Already have an account? Log in</button>
  </div>
</div>

<!-- ── LOGIN ── -->
<div id="login" class="page">
  <div class="login-box" style="margin:auto;">
    <div class="login-logo">🎓 CollegMate</div>
    <div class="login-sub">Welcome back! Enter your email to continue.</div>
    <div id="login-error" class="error-msg"></div>
    <div class="form-field">
      <label>Email Address</label>
      <input type="email" id="login-email" placeholder="your@college.edu"/>
    </div>
    <button class="btn-login" onclick="doLogin()">🚀 Let's Go</button>
    <div class="login-switch">
      Don't have an account? <a onclick="showPage('onboarding')">Create one →</a>
    </div>
  </div>
</div>

<!-- ── ONBOARDING ── -->
<div id="onboarding" class="page">
  <div class="onboard-header">
    <h1>🎓 CollegMate</h1>
    <p>Set up your profile — takes 2 mins!</p>
    <div class="progress-bar">
      <div class="progress-fill" id="progress" style="width:16%"></div>
    </div>
  </div>
  <div class="onboard-body">
    <div id="ob-error" class="error-msg"></div>

    <!-- Step 1: Name -->
    <div class="step-panel active" id="step-1">
      <div class="step-label">Step 1 of 6</div>
      <div class="step-title">What's your name? 👋</div>
      <div class="step-sub">This is what others will see on your profile.</div>
      <div class="form-field">
        <label>Full Name</label>
        <input type="text" id="ob-name" placeholder="e.g. Priya Sharma" maxlength="60"/>
      </div>
      <button class="btn-next" onclick="nextStep(1)">Continue →</button>
    </div>

    <!-- Step 2: Age -->
    <div class="step-panel" id="step-2">
      <div class="step-label">Step 2 of 6</div>
      <div class="step-title">How old are you? 🎂</div>
      <div class="step-sub">You must be 18 or older to use CollegMate.</div>
      <div class="form-field">
        <label>Age</label>
        <input type="number" id="ob-age" placeholder="e.g. 20" min="18" max="30"/>
      </div>
      <button class="btn-next" onclick="nextStep(2)">Continue →</button>
      <button class="btn-back" onclick="prevStep(2)">← Back</button>
    </div>

    <!-- Step 3: Gender -->
    <div class="step-panel" id="step-3">
      <div class="step-label">Step 3 of 6</div>
      <div class="step-title">I identify as... 🌈</div>
      <div class="step-sub">This helps us find the right matches for you.</div>
      <div class="gender-grid">
        <button class="gender-btn" data-val="male" onclick="selectGender(this)">
          <span class="gender-icon">👨</span>Male
        </button>
        <button class="gender-btn" data-val="female" onclick="selectGender(this)">
          <span class="gender-icon">👩</span>Female
        </button>
        <button class="gender-btn" data-val="non-binary" onclick="selectGender(this)">
          <span class="gender-icon">🧑</span>Non-binary
        </button>
        <button class="gender-btn" data-val="other" onclick="selectGender(this)">
          <span class="gender-icon">🦋</span>Other
        </button>
      </div>
      <button class="btn-next" onclick="nextStep(3)" style="margin-top:1.5rem">Continue →</button>
      <button class="btn-back" onclick="prevStep(3)">← Back</button>
    </div>

    <!-- Step 4: College -->
    <div class="step-panel" id="step-4">
      <div class="step-label">Step 4 of 6</div>
      <div class="step-title">Where do you study? 🏛️</div>
      <div class="step-sub">Your college, university or institution.</div>
      <div class="form-field">
        <label>College / University</label>
        <input type="text" id="ob-college" placeholder="e.g. Delhi University" maxlength="150"/>
      </div>
      <button class="btn-next" onclick="nextStep(4)">Continue →</button>
      <button class="btn-back" onclick="prevStep(4)">← Back</button>
    </div>

    <!-- Step 5: Bio -->
    <div class="step-panel" id="step-5">
      <div class="step-label">Step 5 of 6</div>
      <div class="step-title">Tell us about you ✨</div>
      <div class="step-sub">Write something fun — your interests, vibe, or what you're looking for!</div>
      <div class="form-field">
        <label>Bio</label>
        <textarea id="ob-bio" placeholder="e.g. Coffee addict ☕ | CS nerd | Looking for someone to explore cafes with..." maxlength="200" oninput="updateCharCount()"></textarea>
        <div class="char-count"><span id="bio-count">0</span>/200</div>
      </div>
      <button class="btn-next" onclick="nextStep(5)">Continue →</button>
      <button class="btn-back" onclick="prevStep(5)">← Back</button>
    </div>

    <!-- Step 6: Email -->
    <div class="step-panel" id="step-6">
      <div class="step-label">Step 6 of 6</div>
      <div class="step-title">Last step! Your email 📧</div>
      <div class="step-sub">We'll use this to identify your account. No spam, promise!</div>
      <div class="form-field">
        <label>Email Address</label>
        <input type="email" id="ob-email" placeholder="your@college.edu"/>
      </div>
      <button class="btn-next" onclick="submitProfile()" id="submit-btn">🎉 Create My Profile!</button>
      <button class="btn-back" onclick="prevStep(6)">← Back</button>
    </div>

  </div>
</div>

<!-- ── MAIN APP ── -->
<div id="app" class="page">
  <div class="topbar">
    <div class="topbar-logo">🎓 CollegMate</div>
    <div class="topbar-actions">
      <button class="icon-btn" onclick="showTab('matches')">💌</button>
      <button class="icon-btn" onclick="showTab('profile')">👤</button>
    </div>
  </div>

  <!-- SWIPE TAB -->
  <div id="tab-swipe" class="swipe-screen">
    <h2>🔥 Discover</h2>
    <div class="card-stack" id="cardStack">
      <!-- cards injected here -->
    </div>
    <div class="no-more" id="noMore">
      <div class="big-emoji">🎉</div>
      <h3>You've seen everyone!</h3>
      <p>Check back later for new CollegMates nearby.</p>
    </div>
    <div class="swipe-actions" id="swipeActions">
      <button class="action-btn btn-nope" onclick="swipe('left')" title="Pass">👎</button>
      <button class="action-btn btn-like" onclick="swipe('right')" title="Like">❤️</button>
      <button class="action-btn btn-super" onclick="superLike()" title="Super Like">⭐</button>
    </div>
  </div>

  <!-- MATCHES TAB -->
  <div id="tab-matches" class="matches-screen">
    <h2>💌 Your Matches</h2>
    <div class="sub" id="matches-sub">Loading...</div>
    <div class="match-list" id="matchList"></div>
  </div>

  <!-- PROFILE TAB -->
  <div id="tab-profile" class="profile-screen">
    <div class="my-profile-card">
      <div class="my-profile-header">
        <div class="my-avatar" id="my-avatar">🧑</div>
        <div class="my-name" id="my-name">—</div>
        <div class="my-college" id="my-college">—</div>
      </div>
      <div class="my-profile-body">
        <div class="info-row"><span class="info-label">Age</span><span class="info-val" id="my-age">—</span></div>
        <div class="info-row"><span class="info-label">Gender</span><span class="info-val" id="my-gender">—</span></div>
        <div class="info-row"><span class="info-label">Email</span><span class="info-val" id="my-email">—</span></div>
        <div class="info-row"><span class="info-label">Bio</span><span class="info-val" id="my-bio" style="text-align:right;max-width:200px">—</span></div>
      </div>
    </div>
    <button class="logout-btn" onclick="logout()">🚪 Log Out</button>
  </div>

  <!-- TAB NAV -->
  <nav class="tab-nav">
    <button class="tab-btn active" id="tab-btn-swipe" onclick="showTab('swipe')">
      <span class="tab-icon">🔥</span>Discover
    </button>
    <button class="tab-btn" id="tab-btn-matches" onclick="showTab('matches')">
      <span class="tab-icon">💌</span>Matches
    </button>
    <button class="tab-btn" id="tab-btn-profile" onclick="showTab('profile')">
      <span class="tab-icon">👤</span>Profile
    </button>
  </nav>
</div>

<!-- MATCH POPUP -->
<div class="match-popup" id="matchPopup">
  <div class="match-popup-box">
    <h2>It's a Match! 🎉</h2>
    <div class="match-popup-avatars" id="popup-avatars">🧑💜🧑</div>
    <p id="popup-msg">You and someone liked each other!</p>
    <button class="btn-grad" onclick="closeMatchPopup()">💬 Start Chatting</button>
    <button class="btn-ghost" onclick="closeMatchPopup()">Keep Swiping</button>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
  // ── CONFIG ──────────────────────────────────────────────────
  const API = 'http://localhost:3000/api'; // Change to your server URL

  // ── STATE ───────────────────────────────────────────────────
  let currentUser = null;
  let profiles = [];
  let currentProfileIndex = 0;
  let obData = { name:'', age:'', gender:'', college:'', bio:'', email:'' };
  let currentStep = 1;

  // ── PAGE ROUTING ────────────────────────────────────────────
  function showPage(id) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.getElementById(id).classList.add('active');
  }

  // ── TOAST ───────────────────────────────────────────────────
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2500);
  }

  // ── ONBOARDING ──────────────────────────────────────────────
  function updateCharCount() {
    const bio = document.getElementById('ob-bio').value;
    document.getElementById('bio-count').textContent = bio.length;
  }

  function selectGender(btn) {
    document.querySelectorAll('.gender-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    obData.gender = btn.dataset.val;
  }

  function updateProgress(step) {
    document.getElementById('progress').style.width = (step / 6 * 100) + '%';
  }

  function nextStep(step) {
    const err = document.getElementById('ob-error');
    err.style.display = 'none';

    if (step === 1) {
      obData.name = document.getElementById('ob-name').value.trim();
      if (!obData.name) { err.textContent = 'Please enter your name.'; err.style.display = 'block'; return; }
    }
    if (step === 2) {
      obData.age = parseInt(document.getElementById('ob-age').value);
      if (!obData.age || obData.age < 18) { err.textContent = 'Must be 18 or older.'; err.style.display = 'block'; return; }
    }
    if (step === 3) {
      if (!obData.gender) { err.textContent = 'Please select a gender.'; err.style.display = 'block'; return; }
    }
    if (step === 4) {
      obData.college = document.getElementById('ob-college').value.trim();
      if (!obData.college) { err.textContent = 'Please enter your college.'; err.style.display = 'block'; return; }
    }
    if (step === 5) {
      obData.bio = document.getElementById('ob-bio').value.trim();
    }

    document.getElementById(`step-${step}`).classList.remove('active');
    currentStep = step + 1;
    document.getElementById(`step-${currentStep}`).classList.add('active');
    updateProgress(currentStep);
    window.scrollTo(0, 0);
  }

  function prevStep(step) {
    document.getElementById(`step-${step}`).classList.remove('active');
    currentStep = step - 1;
    document.getElementById(`step-${currentStep}`).classList.add('active');
    updateProgress(currentStep);
  }

  async function submitProfile() {
    obData.email = document.getElementById('ob-email').value.trim();
    const err = document.getElementById('ob-error');
    err.style.display = 'none';

    if (!obData.email || !obData.email.includes('@')) {
      err.textContent = 'Please enter a valid email.'; err.style.display = 'block'; return;
    }

    const btn = document.getElementById('submit-btn');
    btn.textContent = '⏳ Creating profile...';
    btn.disabled = true;

    try {
      const res = await fetch(`${API}/register`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(obData)
      });
      const data = await res.json();
      if (!res.ok) { err.textContent = data.error || 'Error creating profile.'; err.style.display = 'block'; btn.textContent = '🎉 Create My Profile!'; btn.disabled = false; return; }
      currentUser = data.user;
      launchApp();
    } catch (e) {
      // Demo mode (no backend)
      currentUser = { id: 999, ...obData };
      launchApp();
    }
  }

  // ── LOGIN ────────────────────────────────────────────────────
  async function doLogin() {
    const email = document.getElementById('login-email').value.trim();
    const err = document.getElementById('login-error');
    err.style.display = 'none';
    if (!email) { err.textContent = 'Please enter your email.'; err.style.display = 'block'; return; }

    try {
      const res = await fetch(`${API}/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });
      const data = await res.json();
      if (!res.ok) { err.textContent = data.error || 'User not found.'; err.style.display = 'block'; return; }
      currentUser = data.user;
      launchApp();
    } catch (e) {
      err.textContent = 'Cannot connect to server. Make sure the backend is running.';
      err.style.display = 'block';
    }
  }

  // ── APP ──────────────────────────────────────────────────────
  function launchApp() {
    showPage('app');
    fillMyProfile();
    loadProfiles();
  }

  function fillMyProfile() {
    const u = currentUser;
    const avatars = ['🧑‍🎓','👩‍🎓','🧑','👩','👨'];
    document.getElementById('my-avatar').textContent = avatars[u.id % avatars.length] || '🧑';
    document.getElementById('my-name').textContent = `${u.name}, ${u.age}`;
    document.getElementById('my-college').textContent = u.college;
    document.getElementById('my-age').textContent = u.age;
    document.getElementById('my-gender').textContent = u.gender;
    document.getElementById('my-email').textContent = u.email;
    document.getElementById('my-bio').textContent = u.bio || '—';
  }

  async function loadProfiles() {
    try {
      const res = await fetch(`${API}/profiles/${currentUser.id}`);
      profiles = await res.json();
    } catch (e) {
      // Demo profiles when no backend
      profiles = [
        { id:1, name:'Priya Sharma', age:20, gender:'female', college:'Delhi University', bio:'Coffee addict ☕ | Literature nerd | Looking for someone to explore cafes with!', emoji:'👩‍🎓', bg:'bg-a' },
        { id:2, name:'Rohan Mehta', age:22, gender:'male', college:'IIT Bombay', bio:'CS student by day, guitarist by night 🎸 | Loves hiking and street food!', emoji:'🧑‍💻', bg:'bg-b' },
        { id:3, name:'Ananya Singh', age:21, gender:'female', college:'Jadavpur University', bio:'Art & Design major 🎨 | Dreamer | Always up for spontaneous road trips', emoji:'👩‍🎨', bg:'bg-c' },
        { id:4, name:'Arjun Patel', age:23, gender:'male', college:'Pune University', bio:'Foodie 🍕 | Football fan | Finance student who laughs too much', emoji:'🧑‍💼', bg:'bg-d' },
        { id:5, name:'Zara Khan', age:20, gender:'female', college:'Hyderabad Central', bio:'Psychology student 🧠 | Bookworm | Midnight stargazer ✨', emoji:'👩‍🔬', bg:'bg-e' },
      ];
    }
    currentProfileIndex = 0;
    renderCards();
  }

  const emojis = ['👩‍🎓','🧑‍💻','👩‍🎨','🧑‍💼','👩‍🔬','🧑‍🎤','👩‍🍳','🧑‍🔬'];
  const bgs = ['bg-a','bg-b','bg-c','bg-d','bg-e'];

  function renderCards() {
    const stack = document.getElementById('cardStack');
    stack.innerHTML = '';
    const actions = document.getElementById('swipeActions');
    const noMore = document.getElementById('noMore');

    const remaining = profiles.slice(currentProfileIndex, currentProfileIndex + 3);
    if (remaining.length === 0) {
      stack.style.display = 'none';
      actions.style.display = 'none';
      noMore.style.display = 'block';
      return;
    }

    stack.style.display = 'block';
    actions.style.display = 'flex';
    noMore.style.display = 'none';

    remaining.reverse().forEach((p, i) => {
      const card = document.createElement('div');
      card.className = 'profile-card' + (i === remaining.length - 1 ? ' top' : '');
      card.id = 'card-' + p.id;
      const bg = p.bg || bgs[p.id % bgs.length];
      const emoji = p.emoji || emojis[p.id % emojis.length];
      card.innerHTML = `
        <div class="card-avatar ${bg}">
          ${emoji}
          <div class="card-college-badge">🏛️ ${p.college}</div>
        </div>
        <div class="card-body">
          <div class="card-name-row">
            <span class="card-name">${p.name}</span>
            <span class="card-age">${p.age}</span>
          </div>
          <div class="card-bio">${p.bio || 'Hey there! 👋'}</div>
        </div>`;
      stack.appendChild(card);
    });
  }

  async function swipe(dir) {
    if (currentProfileIndex >= profiles.length) return;
    const profile = profiles[currentProfileIndex];
    const topCard = document.querySelector('.profile-card.top');
    if (!topCard) return;

    topCard.classList.remove('top');
    topCard.classList.add(dir === 'right' ? 'swipe-right' : 'swipe-left');

    if (dir === 'right') {
      showToast('❤️ Liked!');
      try {
        const res = await fetch(`${API}/like`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ fromUser: currentUser.id, toUser: profile.id })
        });
        const data = await res.json();
        if (data.isMatch) {
          setTimeout(() => showMatchPopup(data.matchedUser || profile), 400);
        }
      } catch (e) {
        if (Math.random() > 0.5) setTimeout(() => showMatchPopup(profile), 400);
      }
    } else {
      showToast('👋 Passed');
    }

    setTimeout(() => {
      currentProfileIndex++;
      renderCards();
    }, 380);
  }

  function superLike() {
    showToast('⭐ Super Liked!');
    swipe('right');
  }

  function showMatchPopup(user) {
    const myEmoji = emojis[currentUser.id % emojis.length] || '🧑';
    const theirEmoji = user.emoji || emojis[(user.id || 1) % emojis.length];
    document.getElementById('popup-avatars').textContent = `${myEmoji} 💜 ${theirEmoji}`;
    document.getElementById('popup-msg').textContent = `You and ${user.name} both liked each other!`;
    document.getElementById('matchPopup').classList.add('show');
    loadMatches();
  }

  function closeMatchPopup() {
    document.getElementById('matchPopup').classList.remove('show');
  }

  // ── MATCHES ──────────────────────────────────────────────────
  async function loadMatches() {
    const list = document.getElementById('matchList');
    const sub = document.getElementById('matches-sub');
    try {
      const res = await fetch(`${API}/matches/${currentUser.id}`);
      const matches = await res.json();
      if (matches.length === 0) {
        sub.textContent = "No matches yet — keep swiping! 💜";
        list.innerHTML = '';
        return;
      }
      sub.textContent = `${matches.length} mutual match${matches.length > 1 ? 'es' : ''} 🎉`;
      list.innerHTML = matches.map((m, i) => {
        const bg = bgs[i % bgs.length];
        const emoji = emojis[i % emojis.length];
        return `<div class="match-card">
          <div class="match-avatar ${bg}">${emoji}</div>
          <div class="match-info">
            <div class="match-name">${m.name}, ${m.age}</div>
            <div class="match-college">🏛️ ${m.college}</div>
            <div class="match-msg">💬 Say hello!</div>
          </div>
          <div class="match-arrow">›</div>
        </div>`;
      }).join('');
    } catch(e) {
      sub.textContent = "Connect to backend to see matches.";
    }
  }

  // ── TABS ─────────────────────────────────────────────────────
  function showTab(tab) {
    ['swipe','matches','profile'].forEach(t => {
      document.getElementById(`tab-${t}`).classList.toggle('active', false);
      if (t !== 'swipe') document.getElementById(`tab-${t}`).style.display = 'none';
      document.getElementById(`tab-btn-${t}`).classList.remove('active');
    });
    document.getElementById(`tab-btn-${tab}`).classList.add('active');
    if (tab === 'swipe') {
      document.getElementById('tab-swipe').style.display = 'flex';
    } else {
      document.getElementById(`tab-${tab}`).style.display = 'block';
      document.getElementById(`tab-${tab}`).classList.add('active');
      document.getElementById('tab-swipe').style.display = 'none';
      if (tab === 'matches') loadMatches();
    }
  }

  // ── LOGOUT ───────────────────────────────────────────────────
  function logout() {
    currentUser = null;
    profiles = [];
    showPage('splash');
  }
</script>
</body>
</html>
